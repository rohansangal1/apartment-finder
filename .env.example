# Which dataClient implementation to use.
#   mock = in-browser fixtures (Phase 0, default)
#   api  = call /api serverless functions (Phase 1, requires apiClient.js)
VITE_DATA_SOURCE=mock

# ---- Phase 1 secrets (server-side only — never prefix with VITE_) ----
# These live in Vercel/Netlify project settings, NOT in client code.
# RENTCAST_API_KEY=
# TRAVELTIME_APP_ID=
# TRAVELTIME_API_KEY=
# GOOGLE_MAPS_API_KEY=

# ---- Phase 2 (Supabase) ----
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
