# ---- Client (safe to expose; bundled into the browser) ----
# Which dataClient implementation to use.
#   mock = in-browser fixtures (Phase 0, default)
#   api  = call /api serverless functions (Phase 1)
VITE_DATA_SOURCE=mock
# Optional: base URL for the API when not same-origin (e.g. local `vercel dev`).
# Leave blank in production — functions are served from the same domain.
# VITE_API_BASE_URL=

# ---- Phase 1 secrets (SERVER-SIDE ONLY — never prefix with VITE_) ----
# These live in Vercel project settings (or .env for local `vercel dev`).
# If any is missing, the matching endpoint returns 503 with a clear message.
# RENTCAST_API_KEY=
# TRAVELTIME_APP_ID=
# TRAVELTIME_API_KEY=
# GOOGLE_MAPS_API_KEY=

# ---- Caching + safety (optional but recommended in production) ----
# Without these the cache + rate limiter fall back to in-process memory, which
# is NOT shared across serverless invocations (fine for dev, weak for prod).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# DAILY_BUDGET_USD=5            # circuit breaker: pause paid calls above this/day
# RATE_LIMIT_MAX=30             # requests per IP per window
# RATE_LIMIT_WINDOW_SEC=60

# ---- Phase 2 (Supabase) ----
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
